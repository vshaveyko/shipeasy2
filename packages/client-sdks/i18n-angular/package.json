{
  "name": "@shipeasy/i18n-angular",
  "version": "1.0.0",
  "description": "Angular integration for ShipEasy i18n",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --clean",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@angular/core": ">=15.0.0",
    "@angular/common": ">=15.0.0",
    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "@angular/core": "^17.0.0",
    "@angular/common": "^17.0.0",
    "rxjs": "^7.8.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@shipeasy/i18n-core": "workspace:*"
  }
}
