{
  "name": "@shipeasy/react",
  "version": "1.0.0",
  "description": "Shipeasy React adapter \u2014 <ShipeasyProvider>, useFlag, useConfig, useExperiment, useShipEasyI18n, plus the devtools overlay loader.",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://shipeasy.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/shipeasy-ai/sdk-react.git"
  },
  "bugs": {
    "url": "https://github.com/shipeasy-ai/sdk-react/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@shipeasy/sdk": "^1.0.0",
    "@shipeasy/i18n-core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.4",
    "vitest": "^2.1.0",
    "jsdom": "^25.0.0",
    "@testing-library/react": "^16.0.1"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
