{
  "name": "@shipeasy/i18n-vue",
  "version": "1.0.0",
  "description": "Vue 3 integration for ShipEasy i18n",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.4",
    "vue": "^3.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@shipeasy/i18n-core": "workspace:*"
  }
}
