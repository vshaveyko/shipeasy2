{
  "name": "@shipeasy/devtools",
  "version": "1.0.0",
  "description": "ShipEasy in-browser developer overlay",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node -e \"require('fs').cpSync('dist/devtools.global.js','../../apps/ui/public/se-devtools.js',{force:true})\"",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.4"
  },
  "sideEffects": false
}
