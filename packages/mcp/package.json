{
  "name": "@shipeasy/mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol server for the Shipeasy platform (experimentation + i18n)",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shipeasy-ai/mcp.git"
  },
  "bin": {
    "shipeasy-mcp": "./bin/mcp.js"
  },
  "exports": {
    "./i18n/scan": {
      "types": "./dist/tools/i18n/scan.d.ts",
      "default": "./dist/tools/i18n/scan.js"
    }
  },
  "files": [
    "bin/",
    "dist/",
    "src/prompts/*.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "start": "node bin/mcp.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@shipeasy/openapi": "workspace:^1.0.0",
    "package-manager-detector": "^1.6.0",
    "typescript": "^5.7.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "tsx": "^4.19.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
