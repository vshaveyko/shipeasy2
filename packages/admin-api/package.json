{
  "name": "@shipeasy/admin-api",
  "version": "0.1.0",
  "private": true,
  "description": "Shared typed client for the Shipeasy admin API. Single source of truth for endpoint paths, request/response shapes, and the resource registry consumed by @shipeasy/cli and @shipeasy/mcp.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./resources/*": {
      "types": "./dist/resources/*.d.ts",
      "default": "./dist/resources/*.js"
    },
    "./transport": {
      "types": "./dist/transport.d.ts",
      "default": "./dist/transport.js"
    },
    "./pagination": {
      "types": "./dist/pagination.d.ts",
      "default": "./dist/pagination.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "emit-openapi": "tsx scripts/emit-spec.ts"
  },
  "dependencies": {
    "@shipeasy/core": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "openapi-types": "^12.1.3",
    "tsup": "^8.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.4",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
