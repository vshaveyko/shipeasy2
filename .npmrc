auto-install-peers=true
shamefully-hoist=false
strict-peer-dependencies=false

# `link-workspace-packages=true` lets a workspace package satisfy a
# `"*"` semver range. The submoduled @shipeasy/{sdk,react,sdk-ruby}
# packages live under packages/*, so when their submodule is initialised
# locally they become workspace members and apps/ui resolves to the
# local copy. When the submodule is NOT initialised (e.g. in CF Workers
# Builds), the directory is empty / has no package.json and pnpm falls
# back to the npm registry — which is exactly what we want for deploys.
link-workspace-packages=true
