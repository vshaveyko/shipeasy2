auto-install-peers=true
shamefully-hoist=false
strict-peer-dependencies=false

# Submoduled @shipeasy/* packages live at packages/sdk, packages/react, etc.
# pnpm 10 defaults link-workspace-packages to false for security; force-enable
# so that `@shipeasy/sdk: ^1.0.0` in packages/react resolves to the local
# submodule, not the npm registry copy. Without this the dev loop is broken
# (edits in packages/sdk wouldn't propagate to packages/react).
link-workspace-packages=true
prefer-workspace-packages=true
