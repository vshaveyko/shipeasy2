{
  "name": "@shipeasy/ui",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui-port 0",
    "test:smoke": "playwright test --config playwright.smoke.config.ts",
    "test:api": "vitest run",
    "build:cf": "opennextjs-cloudflare build && node scripts/stub-image-handler.mjs",
    "deploy": "pnpm build:cf && opennextjs-cloudflare deploy",
    "upload": "pnpm build:cf && opennextjs-cloudflare upload",
    "preview": "pnpm build:cf && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@conform-to/react": "^1.3.0",
    "@conform-to/zod": "^1.3.0",
    "@opennextjs/cloudflare": "^1.19.1",
    "@shipeasy/core": "workspace:*",
    "@shipeasy/devtools": "workspace:*",
    "@shipeasy/react": "workspace:*",
    "@shipeasy/sdk": "workspace:*",
    "@shipeasy/shared": "workspace:*",
    "@tanstack/react-virtual": "^3.13.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.36.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-auth": "^5.0.0-beta.31",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "stripe": "^17.0.0",
    "swr": "^2.3.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitest/coverage-v8": "^2.1.9",
    "better-sqlite3": "^12.9.0",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "tailwindcss": "^4",
    "typescript": "^5.7.4",
    "vitest": "^2.1.9",
    "wrangler": "^4.83.0"
  }
}
