{
  "name": "shipeasy",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "type-check": "turbo type-check",
    "format": "prettier --write .",
    "prepare": "husky",
    "migrate": "pnpm --filter @shipeasy/worker exec wrangler d1 migrations apply shipeasy-db --remote",
    "deploy": "pnpm build && pnpm migrate && pnpm --filter @shipeasy/worker deploy && pnpm --filter @shipeasy/ui deploy",
    "deploy:docs": "pnpm --filter @shipeasy/docs deploy"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ],
    "*.{json,md,mdx,yaml,yml,css}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.4",
    "typescript-eslint": "^8.58.2"
  }
}
